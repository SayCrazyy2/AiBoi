# Copy this to `.env` for local Docker testing, or set these as environment
# variables in your platform's dashboard (Railway: Service -> Variables).
# On Railway/Docker/systemd, no config.yaml or wizard is needed at all --
# `ai serve` builds its config entirely from variables like these.

# -- at least one model provider key --
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# -- assistant defaults --
AI_DEFAULT_MODEL=claude-sonnet-5
AI_SYSTEM_PROMPT=
AI_ENABLE_FILESYSTEM=true
AI_ENABLE_HTTP=true
AI_ENABLE_SHELL=false

# -- Telegram bot (leave blank to disable) --
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_MODEL=

# -- Discord bot (leave blank to disable) --
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_COMMAND_PREFIX=!ai 
DISCORD_MODEL=

# -- platform plumbing (usually set automatically -- don't set by hand) --
# PORT=8080                    # Railway sets this; ai serve binds a health check to it
# AI_CLI_NONINTERACTIVE=1      # forces non-wizard, env-var-only config
# AI_CLI_HOME=/data/.ai-cli    # where config/sessions/.env live
